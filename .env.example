# ============================================================
# DPP × QuickBooks Integration — Environment Configuration
# ============================================================
# Copy to .env.local for development, set in Railway for prod

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── QuickBooks OAuth 2.0 ─────────────────────────────────────
QB_CLIENT_ID=your-client-id
QB_CLIENT_SECRET=your-client-secret
QB_REDIRECT_URI=http://localhost:3000/api/quickbooks/callback
QB_ENVIRONMENT=sandbox
# Production values:
# QB_ENVIRONMENT=production
# QB_REDIRECT_URI=https://your-domain.com/api/quickbooks/callback

# ── QuickBooks Webhooks ──────────────────────────────────────
QB_WEBHOOK_VERIFIER_TOKEN=your-webhook-verifier-token

# ── DPP / Deluxe Gateway Webhooks ────────────────────────────
# Deluxe does NOT sign its outbound webhooks, so we authenticate them via:
#   (1) a high-entropy secret embedded in the registered webhook URL, and
#   (2) a source-IP allowlist.
# Register the eventUri with Deluxe as:
#   https://<your-domain>/api/webhooks/dpp?token=<DPP_WEBHOOK_URL_SECRET>
DPP_WEBHOOK_URL_SECRET=generate-a-32-char-random-string
# Comma-separated allowlist of Deluxe source IPs. REQUIRED in production.
DPP_ALLOWED_IPS=168.135.248.101

# ── DPP / Deluxe API (server-side, for auto-subscribing webhooks) ─────
# From your Deluxe Integrations team (isvinquiries@deluxe.com). Used during
# onboarding to subscribe each merchant's MID to TRANSACTION + ACH REJECT.
DPP_CLIENT_ID=your-deluxe-client-id
DPP_CLIENT_SECRET=your-deluxe-client-secret
DPP_PARTNER_TOKEN=your-deluxe-partner-token
DPP_API_BASE=https://api.deluxe.com
# Optional: override the subscribe `userName` (defaults to each merchant's MID).
# DPP_SUBSCRIBE_USERNAME=

# ── Onboarding & Admin ───────────────────────────────────────
# Signs merchant onboarding links (/onboard?mid&ts&sig). 32+ random chars.
ONBOARD_SECRET=generate-a-32-char-random-string
# Single shared password for the operator admin panel (/admin).
ADMIN_PASSWORD=choose-a-strong-admin-password
# Shared secret for signed embed URLs (iframe integration). 32+ random chars.
EMBED_SECRET=generate-a-32-char-random-string

# ── Email (Resend) ───────────────────────────────────────────
RESEND_API_KEY=your-resend-api-key
# Operator alerts (sync failures, daily digest). Full "Name <email>" form.
ALERT_EMAIL_FROM=PaySync <alerts@your-domain.com>
ALERT_EMAIL_TO=ops@your-domain.com
# Customer invoice/reminder emails. A BARE verified sending address on your
# Resend-verified domain (the merchant's business name becomes the display name).
INVOICE_EMAIL_FROM=billing@your-domain.com

# ── Cron / Scheduled Jobs ────────────────────────────────────
# Bearer token protecting /api/invoices/reminders and /api/sync/retry.
CRON_SECRET=generate-a-32-char-random-string

# ── Security ─────────────────────────────────────────────────
ENCRYPTION_KEY=generate-a-32-byte-hex-key
SESSION_SECRET=generate-a-64-char-random-string
CSRF_SECRET=generate-a-32-char-random-string

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000
